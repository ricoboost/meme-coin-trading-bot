PAPER_ENTRY_MIN_ROUNDTRIP_RATIO_SNIPER=0.78
PAPER_ENTRY_MAX_PRICE_IMPACT_PCT_SNIPER=0.25
# Wallet lane on pump.fun quotes 5-15% impact on 0.05 SOL buys — venue texture,
# not a rejection signal. Keep roundtrip ratio (0.85) as the real "pool dead" check.
PAPER_ENTRY_MIN_ROUNDTRIP_RATIO_WALLET=0.85
PAPER_ENTRY_MAX_PRICE_IMPACT_PCT_WALLET=0.35
PAPER_ENTRY_MIN_ROUNDTRIP_RATIO_WALLET_PUMP_FUN=0.85
PAPER_ENTRY_MAX_PRICE_IMPACT_PCT_WALLET_PUMP_FUN=10.0
