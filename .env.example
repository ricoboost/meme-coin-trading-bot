# ---- Provider D Analytics wallet collector ----
# Fill PROVIDER_D_SOLANA_WALLETS_QUERY_ID with the numeric id of a Provider D query that
# returns Solana wallet addresses. PROVIDER_D_WALLET_COLUMN is the column name in
# the query result holding the wallet (e.g. "wallet", "trader", "address").
# PROVIDER_D_LABEL_COLUMN is optional.
PROVIDER_D_API_KEY=
PROVIDER_D_SOLANA_WALLETS_QUERY_ID=
PROVIDER_D_WALLET_COLUMN=wallet
PROVIDER_D_LABEL_COLUMN=
