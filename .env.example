LIVE_ENTRY_MAX_PRICE_IMPACT_PCT_WALLET_PUMP_FUN=10.0
LIVE_ENTRY_MAX_PRICE_IMPACT_PCT_WALLET_PUMP_AMM=10.0
CANDIDATE_RANKING_WINDOW_SEC=0.5
CANDIDATE_QUEUE_MIN_SIZE=2
CANDIDATE_MIN_SCORE=0.0
# ---- ML entry filter ----
# off: disabled
# shadow: score only (default, no trade blocking)
# gate: block entries below threshold
ML_MODE=shadow
ML_MODEL_BACKEND=auto
ML_MODEL_PATH=models/entry_filter_model.joblib
ML_SAMPLES_PATH=data/live/ml_samples.jsonl
ML_BOOTSTRAP_ENABLE=true
