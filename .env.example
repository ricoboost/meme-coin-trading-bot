LIVE_PUMP_AMM_SELL_COMPUTE_UNIT_LIMIT=350000

# ---- Rug-protection entry guards (live mode) ----
# Freeze authority: reject mints whose freeze_authority is still live.
# Strongly recommended; off by default would let freeze-rugs through.
LIVE_ENTRY_REQUIRE_FREEZE_AUTHORITY_NULL=true
# Mint authority: reject mints whose mint_authority is still live (dilution
# risk). Off by default because many healthy mints keep it for burns/airdrops.
LIVE_ENTRY_REQUIRE_MINT_AUTHORITY_NULL=false
# Top-1 non-pool holder max share (existing guard).
LIVE_ENTRY_MAX_TOP_HOLDER_PCT=0.10
# Top-5 non-pool holders summed share — catches distributed sniper bundles
# that split a dev allocation across multiple wallets.
LIVE_ENTRY_MAX_TOP5_HOLDER_PCT=0.25
# Pre-buy honeypot detection via atomic simulateBundle(buy, sell). Opt-in —
# requires an RPC that supports simulateBundle (Helius, Jito Block Engine).
# No-op if the RPC rejects the method.
LIVE_ENTRY_HONEYPOT_SIM_ENABLED=false
LIVE_ENTRY_HONEYPOT_SIM_FRACTION_BPS=500

TRACKED_WALLETS_PATH=data/bronze/wallet_pool.parquet
# Optional in pair_first mode. Keep set if you still want wallet-score bonuses.
# Drop wallets that never ranked on provider_a AND look like bagholders (≥10 active,
# ≤2 closed/30d). Keeps cluster signal to real snipers, not accumulators.
WALLET_POOL_EXCLUDE_BAGHOLDERS=true
RULES_SOURCE_MODE=pump
PUMP_RULES_PATH=outputs/rules/pump_rule_packs_v2.csv
ALLOW_LEGACY_RULE_FALLBACK=false
FINAL_SUMMARY_PATH=outputs/reports/final_research_summary.json
TOP_RULES_PATH=outputs/reports/final_research_summary_top_rules.csv
TRUSTED_RULES_PATH=outputs/rules/trusted_rule_shortlist.csv
REGIME_COMPARISON_PATH=outputs/reports/regime_comparison.csv

# ---- Trading mode ----
# Paper mode is the default. Set ENABLE_AUTO_TRADING=true ONLY if you
# understand the risks and want to execute real trades with real SOL.
ENABLE_AUTO_TRADING=false
ENABLE_PAPER_TRADING=true

ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional regime filter. Leave empty to keep all Pump V2 rules.
OPTIONAL_ALLOWED_REGIMES=
